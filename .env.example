# Configuración de Base de Datos MySQL
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_USER=proyecto_user
MYSQL_PASSWORD=changeme123!
MYSQL_DATABASE=proyecto_db
MYSQL_ROOT_PASSWORD=root123!

# Configuración de la Aplicación
APP_ENV=development
APP_NAME=API Gestión de Tareas
APP_VERSION=1.0.0
SECRET_KEY=tu-clave-secreta-aqui
LOG_LEVEL=INFO

# Configuración de OpenAI (para generación de historias y tareas)
# Opción 1: OpenAI API
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4-turbo-preview

# Opción 2: Azure OpenAI
# AZURE_OPENAI_API_KEY=...
# AZURE_OPENAI_ENDPOINT=https://<nombre>.openai.azure.com/
# AZURE_OPENAI_DEPLOYMENT=<nombre-deployment>

# Variables de control
AI_ENABLED=false
AI_PROVIDER=openai  # openai o azure_openai
